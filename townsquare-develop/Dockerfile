FROM node:20-alpine AS builder

WORKDIR /app

ARG VUE_APP_UNICLOUD_PROVIDER
ARG VUE_APP_UNICLOUD_SPACE_ID
ARG VUE_APP_UNICLOUD_CLIENT_SECRET
ARG VUE_APP_UNICLOUD_ENDPOINT
ARG VUE_APP_TOWNSQUARE_WS_URL
ARG VUE_APP_VOICE_STUN_URLS
ARG VUE_APP_VOICE_TURN_URLS
ARG VUE_APP_VOICE_TURN_USERNAME
ARG VUE_APP_VOICE_TURN_CREDENTIAL

ENV VUE_APP_UNICLOUD_PROVIDER=$VUE_APP_UNICLOUD_PROVIDER
ENV VUE_APP_UNICLOUD_SPACE_ID=$VUE_APP_UNICLOUD_SPACE_ID
ENV VUE_APP_UNICLOUD_CLIENT_SECRET=$VUE_APP_UNICLOUD_CLIENT_SECRET
ENV VUE_APP_UNICLOUD_ENDPOINT=$VUE_APP_UNICLOUD_ENDPOINT
ENV VUE_APP_TOWNSQUARE_WS_URL=$VUE_APP_TOWNSQUARE_WS_URL
ENV VUE_APP_VOICE_STUN_URLS=$VUE_APP_VOICE_STUN_URLS
ENV VUE_APP_VOICE_TURN_URLS=$VUE_APP_VOICE_TURN_URLS
ENV VUE_APP_VOICE_TURN_USERNAME=$VUE_APP_VOICE_TURN_USERNAME
ENV VUE_APP_VOICE_TURN_CREDENTIAL=$VUE_APP_VOICE_TURN_CREDENTIAL
ENV PUPPETEER_SKIP_DOWNLOAD=true

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM node:20-bookworm-slim AS live

WORKDIR /app

ENV NODE_ENV=development
ENV PUPPETEER_SKIP_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    chromium \
    fonts-noto-cjk \
    fonts-noto-color-emoji \
  && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm ci --omit=dev

COPY server ./server

EXPOSE 8081

CMD ["node", "server/index.js"]

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
