FROM node:20-alpine AS builder

WORKDIR /app

ARG VUE_APP_UNICLOUD_PROVIDER
ARG VUE_APP_UNICLOUD_SPACE_ID
ARG VUE_APP_UNICLOUD_CLIENT_SECRET
ARG VUE_APP_UNICLOUD_ENDPOINT
ARG VUE_APP_TOWNSQUARE_WS_URL

ENV VUE_APP_UNICLOUD_PROVIDER=$VUE_APP_UNICLOUD_PROVIDER
ENV VUE_APP_UNICLOUD_SPACE_ID=$VUE_APP_UNICLOUD_SPACE_ID
ENV VUE_APP_UNICLOUD_CLIENT_SECRET=$VUE_APP_UNICLOUD_CLIENT_SECRET
ENV VUE_APP_UNICLOUD_ENDPOINT=$VUE_APP_UNICLOUD_ENDPOINT
ENV VUE_APP_TOWNSQUARE_WS_URL=$VUE_APP_TOWNSQUARE_WS_URL

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM node:20-alpine AS live

WORKDIR /app

ENV NODE_ENV=development

COPY package*.json ./
RUN npm ci --omit=dev

COPY server ./server

EXPOSE 8081

CMD ["node", "server/index.js"]

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
