{
  "bsonType": "object",
  "required": ["email", "passwordHash", "status"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "用户 ID"
    },
    "email": {
      "bsonType": "string",
      "description": "登录邮箱"
    },
    "nickname": {
      "bsonType": "string",
      "description": "昵称"
    },
    "passwordHash": {
      "bsonType": "string",
      "description": "密码哈希"
    },
    "status": {
      "bsonType": "string",
      "enum": ["active", "disabled"],
      "default": "active"
    },
    "registerTime": {
      "bsonType": "timestamp"
    },
    "lastLoginTime": {
      "bsonType": "timestamp"
    }
  }
}
