{
  "bsonType": "object",
  "required": ["status"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "用户 ID"
    },
    "email": {
      "bsonType": "string",
      "description": "登录邮箱"
    },
    "nickname": {
      "bsonType": "string",
      "description": "昵称"
    },
    "avatarUrl": {
      "bsonType": "string",
      "description": "微信头像"
    },
    "passwordHash": {
      "bsonType": "string",
      "description": "密码哈希"
    },
    "wxOpenid": {
      "bsonType": "string",
      "description": "微信小程序 openid"
    },
    "wxUnionid": {
      "bsonType": "string",
      "description": "微信 unionid"
    },
    "loginType": {
      "bsonType": "string",
      "enum": ["email", "weixin-mp"],
      "description": "登录方式"
    },
    "status": {
      "bsonType": "string",
      "enum": ["active", "disabled"],
      "default": "active"
    },
    "registerTime": {
      "bsonType": "timestamp"
    },
    "lastLoginTime": {
      "bsonType": "timestamp"
    }
  }
}
