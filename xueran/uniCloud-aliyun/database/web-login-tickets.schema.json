{
  "bsonType": "object",
  "required": ["ticket", "status", "expireTime"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "Web login ticket document ID"
    },
    "ticket": {
      "bsonType": "string",
      "description": "Web QR login ticket"
    },
    "status": {
      "bsonType": "string",
      "enum": ["pending", "approved", "consumed", "expired"],
      "description": "Ticket status"
    },
    "userId": {
      "bsonType": "string",
      "description": "Approved user ID"
    },
    "createTime": {
      "bsonType": "timestamp"
    },
    "expireTime": {
      "bsonType": "timestamp"
    },
    "approvedTime": {
      "bsonType": "timestamp"
    },
    "consumedTime": {
      "bsonType": "timestamp"
    },
    "webClient": {
      "bsonType": "object",
      "description": "Web client information"
    },
    "miniappClient": {
      "bsonType": "object",
      "description": "Mini program client information"
    }
  }
}
